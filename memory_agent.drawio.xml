        <mxCell id="9X_zHYVDyfRs_1JNDdcn-13" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#d5e8d4;strokeColor=#82b366;" value="Final commit node&lt;div&gt;Merge validated state.candidate into state.existing&lt;/div&gt;&lt;div&gt;Deterministic merge / reducer logic lives here&lt;/div&gt;" vertex="1">
